# ============================================================
# DatSanVN — Environment Variables
# Copy to .env và điền giá trị thật
# ============================================================

# Database (Neon PostgreSQL)
# DATABASE_URL: Pooler endpoint (cho runtime queries)
DATABASE_URL="postgresql://neondb_owner:PASSWORD@ENDPOINT-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
# DIRECT_URL: Non-pooler endpoint (cho migrations)
DIRECT_URL="postgresql://neondb_owner:PASSWORD@ENDPOINT.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
# PrismaPg adapter uses node-postgres pooling; keep this low for Supabase/Neon poolers.
# If switching back to Prisma's default connector, use ?connection_limit=5 on DATABASE_URL instead.
DB_POOL_MAX=5

# Redis (BullMQ booking expiration + booking idempotency)
# Development can use localhost. Production must set REDIS_URL or REDIS_HOST.
# Use rediss:// or REDIS_TLS=true for managed Redis providers that require TLS.
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_DB=0
REDIS_TLS=false
# Payment/booking slot hold before unpaid PENDING booking auto-expires.
PAYMENT_HOLD_MINUTES=5
# Deprecated: do not set BOOKING_EXPIRATION_MINUTES. The app rejects values other than 5.
BOOKING_IDEMPOTENCY_TTL_SECONDS=90
PAYMENT_INITIATION_IDEMPOTENCY_TTL_SECONDS=900

# Payment
# Mock provider/completion are opt-in local tools only. Do not enable in production.
PAYMENT_MOCK_PROVIDER_ENABLED=false
ENABLE_MOCK_PAYMENT=false
PAYMENT_RETURN_BASE_URL="http://localhost:3001"
PAYMENT_WEBHOOK_BASE_URL="http://localhost:3000/api"

# Payment provider sandbox stubs (disabled by default; placeholders only)
MOMO_SANDBOX_ENABLED=false
MOMO_PARTNER_CODE=""
MOMO_ACCESS_KEY=""
MOMO_SECRET_KEY=""
MOMO_SANDBOX_ENDPOINT=""
MOMO_SANDBOX_TIMEOUT_MS=10000

# Manual MoMo transfer flow. No MoMo API credentials or callback are used.
# Place a local QR image at apps/api/uploads/momo-qr.png, served as /uploads/momo-qr.png in local disk mode.
MOMO_MANUAL_ENABLED=true
MOMO_MANUAL_RECEIVER_NAME="DAT SAN VN"
MOMO_MANUAL_PHONE="09xxxxxxxx"
MOMO_MANUAL_QR_IMAGE_URL="http://localhost:3000/uploads/momo-qr.png"
MOMO_MANUAL_TRANSFER_PREFIX="DSVN"

# VNPay sandbox demo.
# VNPAY_RETURN_URL can use localhost for browser redirects.
# VNPay server-side IPN cannot reach localhost; use ngrok for VNPAY_IPN_URL
# or rely on the app's signed VNPay return verification for local demos.
VNPAY_SANDBOX_ENABLED=false
VNPAY_TMN_CODE=""
VNPAY_HASH_SECRET=""
VNPAY_PAY_URL="https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
VNPAY_RETURN_URL="http://localhost:3001/payments/return"
VNPAY_IPN_URL="http://localhost:3000/api/payments/webhooks/vnpay"

# Upload storage
# Development may use local disk. Production must use Supabase Storage.
# Local disk URLs are served only when NODE_ENV!="production" and UPLOAD_STORAGE_DRIVER=local.
UPLOAD_STORAGE_DRIVER="local" # local | supabase
SUPABASE_URL="https://PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="service_role_xxxxxxxxxxxxxxxxxxxx"
SUPABASE_STORAGE_BUCKET="venue-images"
# Optional CDN/base URL. If omitted, API derives Supabase public object URLs.
# Bucket or CDN path must be publicly readable for frontend image rendering.
SUPABASE_STORAGE_PUBLIC_URL="https://PROJECT_REF.supabase.co/storage/v1/object/public/venue-images"

# Clerk Authentication
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxx"
CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxx"

# Server
PORT=3000
NODE_ENV="development"
